<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60" fill="none">
  <!-- Shield body -->
  <path d="M30 4 L53 14 L53 33 Q53 47 30 56 Q7 47 7 33 L7 14 Z" fill="#175DDC"/>
  <!-- Shield highlight -->
  <path d="M30 9 L49 17.5 L49 33 Q49 44 30 51 Q11 44 11 33 L11 17.5 Z" fill="#1A6AEF" opacity="0.3"/>
  <!-- Lock body -->
  <rect x="20" y="31" width="20" height="14" rx="2.5" fill="white"/>
  <!-- Lock shackle -->
  <path d="M24 31 L24 25 Q24 18.5 30 18.5 Q36 18.5 36 25 L36 31" stroke="white" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Keyhole dot -->
  <circle cx="30" cy="37" r="2.5" fill="#175DDC"/>
  <!-- Keyhole stem -->
  <rect x="28.75" y="37" width="2.5" height="3.5" rx="1" fill="#175DDC"/>
</svg>
